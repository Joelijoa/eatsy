{
  "expo": {
    "name": "Eatsy",
    "slug": "eatsy",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/Icon2.0.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Icon2.0.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eatsy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icon2.0.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.eatsy.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "42843bb1-0ec5-4d2a-a66d-c434fe9ce22b"
      }
    }
  }
}
